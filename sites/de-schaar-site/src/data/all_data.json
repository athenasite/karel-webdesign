    },
    {
      "testimonial_id": 3,
      "klant_naam": "Stien",
      "gebruikte_service": "haarstyling",
      "beoordeling_tekst": "Keer op keer een aangename ontvangst in een zeer proper salon! De producten die ze gebruiken van Aveda zijn eerlijk en natuurlijk. De kappers/kapsters bekijken je haar en gezicht voor ze knippen en geven tijdens het knippen advies. Nog nooit met een slecht gevoel buitengekomen! Voor Corona kreeg je een fijne massage van nek en rug, tijdens het knippen een handmassage en een drankje. Een aanrader!",
      "datum_review": "",
      "is_actief": true,
      "afbeelding": "AQMB3ot7xeCwNsJj94bGlpErEkAokrgq3rfYMqSzZtACGTGxxmDOfJAYt_Jg25lojT8p06S5Di96DIcBywG7WIL9gtf9vClCaeo7OlDM_PNcaLOp_u3FKlOFx4yunpQ64jc8yUlOp3eYGBaqa_suwHIUd731-1770992775410.jpg"
