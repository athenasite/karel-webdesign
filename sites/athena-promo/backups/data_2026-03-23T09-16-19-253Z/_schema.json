  "version": "2.0",
  "design_system": {
    "colors": {
      "primary": "#0f172a",
      "secondary": "#64748b",
      "accent": "#3b82f6",
      "background": "#ffffff",
      "surface": "#f8fafc",
      "text": "#1e293b"
    },
    "font_sans": "'Inter', ui-sans-serif, system-ui, sans-serif",
    "font_serif": "'Playfair Display', ui-serif, Georgia, serif",
    "radius": "1rem"
  }
}