{
  "blueprint_name": "athena-cms-factory-promo",
  "description": "Conversie-gerichte landingspagina voor de Athena CMS Factory. Gericht op Vlaamse KMO's die nood hebben aan een high-end website via AI-automatisatie.",
  "features": {
    "ecommerce": false,
    "google_search_links": false,
    "search_context": "Athena CMS Factory website laten maken KMO Vlaanderen AI automatisatie"
  },
  "data_structure": [
    {
      "table_name": "site_settings",
      "columns": [
        "site_name",
        "tagline",
        "logo_text",
        "footer_text"
      ]
    },
    {
      "table_name": "contact",
      "columns": [
        "titel",
        "email",
        "telefoon",
        "locatie",
        "btw_nummer",
        "linkedin_url"
      ]
    },
    {
      "table_name": "hero",
      "columns": [
        "titel",
        "ondertitel",
        "cta_label",
        "cta_url",
        "hero_afbeelding"
      ]
    },
    {
      "table_name": "intro",
      "columns": [
        "titel",
        "missie_visie",
        "foto_url",
        "cta_label",
        "cta_url"
      ]
    },
    {
      "table_name": "voordelen",
      "columns": [
        "titel",
        "beschrijving",
        "icoon"
      ]
    },
    {
      "table_name": "innovatie",
      "columns": [
        "category",
        "skills"
      ]
    },
    {
      "table_name": "showcase",
      "columns": [
        "naam",
        "categorie",
        "beschrijving",
        "url",
        "afbeelding"
      ]
    },
    {
      "table_name": "proces",
      "columns": [
        "stap",
        "titel",
        "tijdsduur",
        "uitleg"
      ]
    }
  ],
  "sections": [
    {
      "id": "hero",
      "title": "Hoofdpagina",
      "fields": {
        "titel": "string",
        "ondertitel": "text",
        "cta_label": "string",
        "cta_url": "string",
        "hero_afbeelding": "image"
      }
    },
    {
      "id": "intro",
      "title": "De Revolutie in Webdesign",
      "fields": {
        "titel": "string",
        "missie_visie": "text",
        "cta_label": "string",
        "cta_url": "string",
        "foto_url": "image"
      }
    },
    {
      "id": "voordelen",
      "title": "Waarom kiezen voor Athena?",
      "fields": {
        "items": [
          {
            "titel": "string",
            "beschrijving": "text",
            "icoon": "string"
          }
        ]
      }
    },
    {
      "id": "innovatie",
      "title": "De Kracht van de Factory",
      "fields": {
        "categories": [
          {
            "name": "string",
            "skills": "text"
          }
        ]
      }
    },
    {
      "id": "showcase",
      "title": "Recent Gerealiseerde Sites",
      "fields": {
        "items": [
          {
            "naam": "string",
            "categorie": "string",
            "beschrijving": "text",
            "url": "string",
            "afbeelding": "image"
          }
        ]
      }
    },
    {
      "id": "proces",
      "title": "Van Aanvraag tot Live in 24u",
      "fields": {
        "items": [
          {
            "stap": "string",
            "titel": "string",
            "tijdsduur": "string",
            "uitleg": "text"
          }
